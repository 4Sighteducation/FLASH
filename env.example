# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# API Keys (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_KEY"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# AI generation models (server-side, optional)
# Leave these unset to preserve current behavior:
# - essay -> gpt-4-turbo
# - multiple_choice / short_answer / acronym -> gpt-3.5-turbo
# For a quality-first test, set OPENAI_MODEL_DEFAULT to a stronger model.
# Per-type values override OPENAI_MODEL_DEFAULT when provided.
OPENAI_MODEL_DEFAULT=""
OPENAI_MODEL_ESSAY=""
OPENAI_MODEL_MULTIPLE_CHOICE=""
OPENAI_MODEL_SHORT_ANSWER=""
OPENAI_MODEL_ACRONYM=""

# Push Notifications
EXPO_PUBLIC_PUSH_NOTIFICATION_PROJECT_ID="YOUR_PROJECT_ID"

# RevenueCat (client-side keys; safe to expose)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY="YOUR_REVENUECAT_IOS_PUBLIC_KEY"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY="YOUR_REVENUECAT_ANDROID_PUBLIC_KEY"

# Google Sign-In (native Android)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="YOUR_GOOGLE_WEB_CLIENT_ID"

# Environment
NODE_ENV=development 